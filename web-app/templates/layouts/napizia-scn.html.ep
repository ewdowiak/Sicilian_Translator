	    <a class="topnav" href="https://dizziunariu.napizia.com/chiu/">chiù dâ palora</a>
	    <!-- <a class="topnav" href="https://www.napizia.com/cgi-bin/aiutami.pl">aiùtami!</a> -->
	    <a class="topnav" href="https://dizziunariu.napizia.com/traina/">dizziunariu traina</a>
	    <a class="topnav" href="https://www.napizia.com/pages/sicilian/poets-sc.shtml">paggina dî pueti</a>
	  </div>
	</li>
	
	<!-- Sicilian -->
	<li class="dropdown">
	  <a href="#" class="dropbtn dbleft">documentazioni</a>
	  <div class="dropdown-content dcleft" style="z-index: 1;">
	    <a class="topnav" href="https://www.napizia.com/pages/sicilian/intro-sc.shtml">introduzioni</a>
	    <a class="topnav" href="https://www.napizia.com/pages/sicilian/translator-sc.shtml">tradutturi sicilianu</a>
	    <!-- <a class="topnav" href="https://www.napizia.com/pages/sicilian/cosine-sim.shtml">cosine similarity</a> -->
	    <a class="topnav" href="https://www.napizia.com/pages/sicilian/trova-palora-sc.shtml">trova na palora</a>
	    <a class="topnav" href="https://www.napizia.com/pages/sicilian/sicilian-verbs-sc.shtml">stivali e ràdica</a>
	    <!-- <a class="topnav" href="https://www.napizia.com/pages/sicilian/index.shtml">specification</a> -->
	    <a class="topnav" href="https://www.napizia.com/pages/sicilian/next-steps-sc.shtml">prossimi passi</a>
	    <a class="topnav" href="https://www.napizia.com/pages/sicilian/bibliography-sc.shtml">bibliografia</a>
	  </div>
	</li>
	
      </ul>
    </div>
  </div>
  <!-- end row div -->

<!-- outer table div continues --> 

<!-- begin outer margin div -->
<div id="outer-margin">

<div class="row">
  <div class="col-m-12 col-12">
<%== $in_hline %>
  </div>
</div>

<!-- begin CONTENT row div -->
<div class="row">

<%== content %>

</div>
<!-- end CONTENT row div -->

</div>  
<!-- end outer margin div -->

<!-- outer table div continues -->

