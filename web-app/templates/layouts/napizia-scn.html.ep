% my $in_title    = $card_title;
% my $in_descrip  = $card_descrip;
% my $in_keywords = $card_keywords;
% my $in_url      = $card_url;
% my $in_image    = $card_image;
% my $in_style    = $page_style;
% my $in_hline    = $page_hline;
<!DOCTYPE html>
<html>
  <head>
    <title><%= $in_title %></title>
    <meta property="og:title" content="<%= $in_title %>">
    <meta name="twitter:title" content="<%= $in_title %>">
    <meta name="DESCRIPTION" content="<%= $in_descrip %>">
    <meta property="og:description" content="<%= $in_descrip %>">
    <meta name="twitter:description" content="<%= $in_descrip %>">
    <meta name="KEYWORDS" content="<%= $in_keywords %>">
    <meta property="og:url" content="<%= $in_url %>">
    <meta name="twitter:url" content="<%= $in_url %>">
    <meta property="og:image" content="<%= $in_image %>">
    <meta name="twitter:image" content="<%= $in_image %>">
    <meta property="og:type" content="website">
    <meta name="twitter:site" content="@ProjectNapizia">
    <meta name="twitter:card" content="summary_large_image">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="Author" content="Eryk Wdowiak">
    <link rel="stylesheet" type="text/css" href="/css/eryk.css">
    <link rel="stylesheet" type="text/css" href="/css/eryk_theme-blue.css">
    <link rel="stylesheet" type="text/css" href="/css/eryk_widenme.css">
    <link rel="stylesheet" type="text/css" href="/css/dieli_forms.css">
    <link rel="stylesheet" type="text/css" href="/css/napizia_translator.css">
    <link rel="stylesheet" type="text/css" href="/css/napizia_darreri.css">
    <link rel="stylesheet" type="text/css" href="/css/napizia_textarea.css">
    <link rel="stylesheet" type="text/css" href="/css/napizia_copy-translation.css">
    <link rel="stylesheet" type="text/css" href="/css/font-awesome.min.css">
    <link rel="stylesheet" type="text/css" href="/css/w3-fa-styles.css">
    <script type="text/javascript" src="/js/textarea-buttons.js"></script>
    <script type="text/javascript" src="/js/copy-translation.js"></script>
    <link rel="icon" type="image/png" href="/config/napizia-icon.png">
    <meta name="viewport" content="width=device-width, initial-scale=1">
<%== $in_style %>
  </head>
  <body>
<!-- begin outer table --> 
<div id="outer-table">
  
  <!-- begin row div -->
  <div class="row">
    <div class="col-12 col-m-12">
      <ul class="topnav">
	
	<!-- home -->
	<li class="dropdown" id="mainitem">
	  <!-- <a class="dropbtn" href="https://www.napizia.com/index.shtml"><b>Napizia</b></a> -->
	  <a href="#" class="dropbtn dbctr"><b>Napizia</b></a>
	  <div class="dropdown-content dcctr" style="z-index: 1;">
	    <a class="topnav" href="https://www.napizia.com/index.shtml">paggina principali</a>
	    <a class="topnav" href="https://www.napizia.com/index-en.shtml">site in english</a>
	    <a class="topnav" href="https://magazine.napizia.com/">napizia magazine</a>
	    <a class="topnav" href="https://www.napizia.com/pages/rhapsody/index.shtml">sicilian rhapsody</a>
	    <a class="topnav" href="https://www.napizia.com/pages/about/index.shtml">viniti a napizia</a>
	  </div>
	</li>	
	
	<!-- Sicilian dictionary -->
	<li class="dropdown">
	  <a href="#" class="dropbtn dbright">dizziunariu</a>
	  <div class="dropdown-content dcright" style="z-index: 1;">
	    <a class="topnav" href="https://dizziunariu.napizia.com/dieli/">dizziunariu dieli</a>
	    <a class="topnav" href="/cgi-bin/index.pl">tradutturi sicilianu</a>
	    <!-- <a class="topnav" href="https://www.napizia.com/cgi-bin/cosine-sim.pl">sumigghianza</a> -->
